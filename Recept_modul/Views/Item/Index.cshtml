@inherits DotNetNuke.Web.Mvc.Framework.DnnWebViewPage<Teszko.ReceptModulRecept_modul.Models.RecipeListViewModel>

@using System
@using DotNetNuke.Web.Mvc.Helpers

@{
    var filters = new[]
    {
        new { Key = "all", Label = "MINDEN" },
        new { Key = "reggeli", Label = "REGGELI" },
        new { Key = "ebed", Label = "EBÉD" },
        new { Key = "vacsora", Label = "VACSORA" },
        new { Key = "snack", Label = "SNACKEK" }
    };
}

<div id="RecipeModule-@Dnn.ModuleContext.ModuleId" class="nc-recipes">
    <section class="nc-recipe-list">
        <h1>Receptek</h1>

        <div class="nc-recipe-search">
            <input type="search" placeholder="Keresés receptnévre" aria-label="Keresés receptnévre" data-recipe-search />
        </div>

        <nav class="nc-filter-bar" aria-label="Recept kategóriák">
            @foreach (var filter in filters)
            {
                var isActive = string.Equals(Model.ActiveMealType, filter.Key, StringComparison.OrdinalIgnoreCase);
                <a class="nc-filter @(isActive ? "is-active" : "")" href="@Url.Action("Index", "Item", new { mealType = filter.Key })">@filter.Label</a>
            }
        </nav>

        @if (Model.Recipes.Count == 0)
        {
            <div class="nc-empty">Most nincs publikált recept ebben a kategóriában.</div>
        }
        else
        {
            <div class="nc-card-grid">
                @foreach (var recipe in Model.Recipes)
                {
                    <article class="nc-recipe-card" data-recipe-card data-recipe-name="@recipe.Name.ToLowerInvariant()">
                        <div class="nc-card-head">
                            <h2>@recipe.Name</h2>
                            <span class="nc-kcal">@recipe.TotalCalories kcal</span>
                        </div>
                        <div class="nc-meta-row">
                            <span>@(recipe.PrepTimeMinutes + recipe.CookTimeMinutes) perc</span>
                            <span>@recipe.Servings főre készítve</span>
                        </div>
                        <a class="nc-card-link" href="@Url.Action("Details", "Item", new { id = recipe.CategoryBvin })">
                            Recept megtekintése <span aria-hidden="true">&gt;</span>
                        </a>
                    </article>
                }
            </div>
            <div class="nc-empty nc-search-empty" data-search-empty>Nincs találat erre a keresésre.</div>
        }
    </section>
</div>

<script>
    (function () {
        var root = document.getElementById("RecipeModule-@Dnn.ModuleContext.ModuleId");
        if (!root) return;

        var input = root.querySelector("[data-recipe-search]");
        var cards = Array.prototype.slice.call(root.querySelectorAll("[data-recipe-card]"));
        var empty = root.querySelector("[data-search-empty]");

        if (!input || cards.length === 0) return;

        input.addEventListener("input", function () {
            var query = input.value.toLowerCase().trim();
            var visibleCount = 0;

            cards.forEach(function (card) {
                var name = card.getAttribute("data-recipe-name") || "";
                var visible = query.length === 0 || name.indexOf(query) >= 0;
                card.style.display = visible ? "" : "none";
                if (visible) visibleCount += 1;
            });

            if (empty) {
                empty.style.display = visibleCount === 0 ? "block" : "none";
            }
        });
    })();
</script>
