@inherits DotNetNuke.Web.Mvc.Framework.DnnWebViewPage<Teszko.ReceptModulRecept_modul.Models.RecipeListViewModel>

@using System
@using DotNetNuke.Web.Mvc.Helpers

@{
    var filters = new[]
    {
        new { Key = "all", Label = "MINDEN" },
        new { Key = "reggeli", Label = "REGGELI" },
        new { Key = "ebed", Label = "EBÉD" },
        new { Key = "vacsora", Label = "VACSORA" },
        new { Key = "snack", Label = "SNACKEK" }
    };
}

<div id="RecipeModule-@Dnn.ModuleContext.ModuleId" class="nc-recipes">
    <section class="nc-recipe-list">
        <h1>Receptek</h1>

        <div class="nc-recipe-search">
            <input type="search" placeholder="Keresés receptnévre" aria-label="Keresés receptnévre" data-recipe-search />
            <input type="search" placeholder="Keresés alapanyagra" aria-label="Keresés alapanyagra" data-ingredient-search />
            <input type="number" min="0" inputmode="numeric" placeholder="Max kcal" aria-label="Maximum kalória" data-filter-kcal />
            <input type="number" min="0" inputmode="numeric" placeholder="Max perc" aria-label="Maximum elkészítési idő" data-filter-time />
            <input type="number" min="1" inputmode="numeric" placeholder="Főre" aria-label="Adag főre" data-filter-servings />
            <button type="button" data-filter-clear>Szűrők törlése</button>
        </div>

        <nav class="nc-filter-bar" aria-label="Recept kategóriák">
            @foreach (var filter in filters)
            {
                var isActive = string.Equals(Model.ActiveMealType, filter.Key, StringComparison.OrdinalIgnoreCase);
                <a class="nc-filter @(isActive ? "is-active" : "")" href="@Url.Action("Index", "Item", new { mealType = filter.Key })">@filter.Label</a>
            }
        </nav>

        @if (Model.Recipes.Count == 0)
        {
            <div class="nc-empty">Most nincs publikált recept ebben a kategóriában.</div>
        }
        else
        {
            <div class="nc-card-grid">
                @foreach (var recipe in Model.Recipes)
                {
                    var detailsUrl = Url.Action("Details", "Item", new { id = recipe.CategoryBvin });
                    var ingredientSearchText = recipe.IngredientSearchText ?? string.Empty;
                    <a class="nc-recipe-card"
                       href="@detailsUrl"
                       aria-label="@recipe.Name recept megtekintése"
                       data-recipe-card
                       data-recipe-name="@recipe.Name.ToLowerInvariant()"
                       data-recipe-ingredients="@ingredientSearchText.ToLowerInvariant()"
                       data-recipe-kcal="@recipe.TotalCalories"
                       data-recipe-time="@(recipe.PrepTimeMinutes + recipe.CookTimeMinutes)"
                       data-recipe-servings="@recipe.Servings">
                        <div class="nc-card-head">
                            <h2>@recipe.Name</h2>
                            <span class="nc-kcal">@recipe.TotalCalories kcal</span>
                        </div>
                        <div class="nc-meta-row">
                            <span>@(recipe.PrepTimeMinutes + recipe.CookTimeMinutes) perc</span>
                            <span>@recipe.Servings főre készítve</span>
                        </div>
                        <span class="nc-card-link">
                            Recept megtekintése <span aria-hidden="true">&gt;</span>
                        </span>
                    </a>
                }
            </div>
            <div class="nc-empty nc-search-empty" data-search-empty>Nincs találat erre a keresésre.</div>
        }
    </section>
</div>

<script>
    (function () {
        var root = document.getElementById("RecipeModule-@Dnn.ModuleContext.ModuleId");
        if (!root) return;

        var input = root.querySelector("[data-recipe-search]");
        var ingredientInput = root.querySelector("[data-ingredient-search]");
        var kcalInput = root.querySelector("[data-filter-kcal]");
        var timeInput = root.querySelector("[data-filter-time]");
        var servingsInput = root.querySelector("[data-filter-servings]");
        var clearButton = root.querySelector("[data-filter-clear]");
        var cards = Array.prototype.slice.call(root.querySelectorAll("[data-recipe-card]"));
        var empty = root.querySelector("[data-search-empty]");

        if (!input || cards.length === 0) return;

        function normalizeText(value) {
            value = (value || "").toLowerCase().trim();
            if (value.normalize) {
                value = value.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
            }

            return value;
        }

        function filterRecipes() {
            var query = normalizeText(input.value);
            var ingredientQuery = normalizeText(ingredientInput && ingredientInput.value);
            var maxKcal = Number(kcalInput && kcalInput.value ? kcalInput.value : 0);
            var maxTime = Number(timeInput && timeInput.value ? timeInput.value : 0);
            var servings = Number(servingsInput && servingsInput.value ? servingsInput.value : 0);
            var visibleCount = 0;

            cards.forEach(function (card) {
                var name = normalizeText(card.getAttribute("data-recipe-name"));
                var ingredients = normalizeText(card.getAttribute("data-recipe-ingredients"));
                var kcal = Number(card.getAttribute("data-recipe-kcal") || 0);
                var time = Number(card.getAttribute("data-recipe-time") || 0);
                var cardServings = Number(card.getAttribute("data-recipe-servings") || 0);
                var visible = query.length === 0 || name.indexOf(query) >= 0;

                visible = visible && (ingredientQuery.length === 0 || ingredients.indexOf(ingredientQuery) >= 0);
                visible = visible && (maxKcal <= 0 || kcal <= maxKcal);
                visible = visible && (maxTime <= 0 || time <= maxTime);
                visible = visible && (servings <= 0 || cardServings === servings);

                card.style.display = visible ? "" : "none";
                if (visible) visibleCount += 1;
            });

            if (empty) {
                empty.style.display = visibleCount === 0 ? "block" : "none";
            }
        }

        input.addEventListener("input", filterRecipes);
        if (ingredientInput) ingredientInput.addEventListener("input", filterRecipes);
        if (kcalInput) kcalInput.addEventListener("input", filterRecipes);
        if (timeInput) timeInput.addEventListener("input", filterRecipes);
        if (servingsInput) servingsInput.addEventListener("input", filterRecipes);
        if (clearButton) {
            clearButton.addEventListener("click", function () {
                input.value = "";
                if (ingredientInput) ingredientInput.value = "";
                if (kcalInput) kcalInput.value = "";
                if (timeInput) timeInput.value = "";
                if (servingsInput) servingsInput.value = "";
                filterRecipes();
            });
        }
    })();
</script>
