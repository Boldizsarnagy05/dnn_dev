<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>

  <appSettings>
    <!-- HotCakes bolt URL (ugyanaz, mint a DNN) -->
    <add key="StoreUrl"  value="https://naturaco.hu" />

    <!-- HotCakes Admin → Configuration → API -->
    <add key="ApiKey"    value="IDE_JON_AZ_API_KEY" />

    <!-- Saját DNN Web API alap URL -->
    <add key="DnnApiUrl" value="https://naturaco.hu" />
  </appSettings>

  <system.net>
    <settings>
      <httpWebRequest useUnsafeHeaderParsing="true" />
    </settings>
  </system.net>
</configuration>
